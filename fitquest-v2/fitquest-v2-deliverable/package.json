{
  "name": "fitquest-v2",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "dompurify": "^3.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "jest": "^29.7.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false --coverage --coverageReporters=text",
    "test:unit": "react-scripts test --watchAll=false src/__tests__/unit",
    "test:security": "react-scripts test --watchAll=false src/__tests__/security"
  },
  "jest": {
    "coverageThreshold": {
      "./src/services/": {
        "statements": 85,
        "functions": 85,
        "lines": 85
      },
      "./src/utils/": {
        "statements": 90,
        "functions": 100,
        "lines": 90
      }
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  }
}
